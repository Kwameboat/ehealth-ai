# API URL — leave empty in production when PWA and API share the same domain
EXPO_PUBLIC_API_URL=http://localhost:3001
# Production same-origin example:
# EXPO_PUBLIC_API_URL=
# Must match APP_API_SECRET in backend/.env
EXPO_PUBLIC_APP_API_SECRET=generate_a_long_random_secret_here
# Optional: Paystack public key (for future inline checkout)
# EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_key_here
