# Public site URL (SEO, sitemap, Open Graph) — use www in production
EXPO_PUBLIC_SITE_URL=https://www.ehealthaigh.com
# Google Search Console HTML tag (content value only)
EXPO_PUBLIC_GOOGLE_SITE_VERIFICATION=EVGPzHgfdl7PWlqlelkWFexwIwDKMB2rVrO7sIGZ5N8
# Bing Webmaster meta content (optional)
# EXPO_PUBLIC_BING_SITE_VERIFICATION=your_bing_verification_code

# API URL — leave empty in production when PWA and API share the same domain
EXPO_PUBLIC_API_URL=http://localhost:3001
# Production same-origin example:
# EXPO_PUBLIC_API_URL=
# Must match APP_API_SECRET in backend/.env
EXPO_PUBLIC_APP_API_SECRET=generate_a_long_random_secret_here
# Optional: Paystack public key (for future inline checkout)
# EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_key_here
