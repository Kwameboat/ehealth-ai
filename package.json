{
  "name": "aimedicalagent",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "node scripts/generate-pwa-icons.mjs && expo export -p web",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs",
    "smoke-test": "node scripts/smoke-test.mjs",
    "deploy:bundle": "node scripts/prepare-deploy.mjs",
    "deploy:sftp": "node scripts/deploy-sftp.mjs",
    "deploy:ssh": "node scripts/deploy-ssh.mjs",
    "start:prod": "npm run build:web && npm --prefix backend start",
    "backend": "npm --prefix backend start",
    "backend:dev": "npm --prefix backend run dev",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/native-stack": "^7.3.25",
    "expo": "~53.0.20",
    "expo-blur": "~14.1.5",
    "expo-constants": "~17.1.7",
    "expo-document-picker": "~13.1.6",
    "expo-file-system": "^18.1.11",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.4.0",
    "expo-image-picker": "^16.1.4",
    "expo-linear-gradient": "^14.1.5",
    "expo-linking": "~7.1.7",
    "expo-location": "^18.1.6",
    "expo-router": "~5.1.4",
    "expo-speech": "^13.1.7",
    "expo-speech-recognition": "^2.1.1",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-symbols": "~0.4.5",
    "expo-system-ui": "~5.0.10",
    "expo-web-browser": "~14.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.5",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-google-mobile-ads": "^15.4.2",
    "react-native-maps": "^1.25.3",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-web": "~0.20.0",
    "react-native-webview": "13.13.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.0.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~9.2.0",
    "sharp": "^0.34.5",
    "ssh2": "^1.17.0",
    "typescript": "~5.8.3"
  },
  "private": true
}
