GEMINI_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
APP_API_SECRET=generate_a_long_random_secret_here
JWT_SECRET=another_long_random_secret_for_jwt
PORT=3001
HOST=127.0.0.1
NODE_ENV=production
# Comma-separated origins for Expo dev / separate frontend host
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# Optional: path to expo export output (default: ../dist in production)
# WEB_DIST_PATH=../dist

# Admin panel login (change in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# SQLite database (use data/ on cPanel — backend/db/ is often not writable)
# DATABASE_PATH=/home/ehealtha/ehealth-ai/data/medassistant.db

# Paystack (https://dashboard.paystack.com)
PAYSTACK_SECRET_KEY=sk_test_your_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_key_here
# Where Paystack redirects after payment (use your public API URL in production)
PAYSTACK_CALLBACK_URL=http://127.0.0.1:3001
